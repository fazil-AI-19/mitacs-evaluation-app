SECRET_KEY=change-me-to-a-long-random-string
# Use an absolute path to avoid SQLite working-directory issues
DATABASE_URL=sqlite:////absolute/path/to/backend/mitacs.db
# Or relative (only reliable when uvicorn is started from the backend/ directory):
# DATABASE_URL=sqlite:///./mitacs.db
UPLOAD_DIR=/absolute/path/to/backend/uploads
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o
ACCESS_TOKEN_EXPIRE_MINUTES=60
